{% comment %} Zaman Optics - Collection Page {% endcomment %}

<!-- Collection Hero Banner -->
<div class="zaman-collection-hero">
  <div class="zaman-collection-hero-inner">
    <div class="zaman-collection-breadcrumb">
      <a href="/">Home</a>
      <span>›</span>
      <span>{{ collection.title }}</span>
    </div>
    <h1 class="zaman-collection-title">
      {{ collection.title }}
    </h1>
    <p class="zaman-collection-desc">
      {% if collection.description != blank %}
        {{ collection.description }}
      {% else %}
        Explore our premium collection of 
        {{ collection.title | downcase }} — 
        crafted for style and clarity.
      {% endif %}
    </p>
    <div class="zaman-collection-meta">
      <span class="zaman-product-count">
        {{ collection.products_count }} Products
      </span>
    </div>
  </div>
</div>

<!-- Main Collection Layout -->
<div class="zaman-collection-page">

  <!-- LEFT: Filter Sidebar -->
  <aside class="zaman-filter-sidebar">
    <form id="ZamanFilterForm" 
          action="{{ collection.url }}" 
          method="get">
      
      <!-- Hidden sort preserve -->
      <input type="hidden" 
             name="sort_by" 
             value="{{ collection.sort_by }}">

      <div class="zaman-filter-card">
        
        <div class="zaman-filter-header">
          <div class="zaman-filter-title-row">
            <svg width="18" height="18" fill="none" 
                 viewBox="0 0 24 24" stroke="#FF8C00" 
                 stroke-width="2">
              <polygon points="22 3 2 3 10 12.46 
                               10 19 14 21 14 12.46 
                               22 3"/>
            </svg>
            <h3>Filters</h3>
          </div>
          <a href="{{ collection.url }}" 
             class="zaman-clear-all">
            Clear All
          </a>
        </div>

        <!-- FRAME SHAPE -->
        <details class="zaman-filter-group" open>
          <summary class="zaman-filter-group-title">
            Frame Shape
            <span class="zaman-filter-arrow">▼</span>
          </summary>
          <div class="zaman-filter-options">
            {% assign shapes = 'Round,Square,Rectangle,Aviator,Cat Eye' | split: ',' %}
            {% for shape in shapes %}
            <label class="zaman-filter-option">
              <input type="checkbox"
                name="filter.p.m.custom.frame_shape"
                value="{{ shape }}"
                class="zaman-filter-check"
                {% if current_tags contains shape %}
                  checked
                {% endif %}
                onchange="document.getElementById(
                  'ZamanFilterForm').submit()">
              <span class="zaman-check-box"></span>
              <span class="zaman-filter-text">
                {{ shape }}
              </span>
            </label>
            {% endfor %}
          </div>
        </details>

        <!-- MATERIAL -->
        <details class="zaman-filter-group" open>
          <summary class="zaman-filter-group-title">
            Material
            <span class="zaman-filter-arrow">▼</span>
          </summary>
          <div class="zaman-filter-options">
            {% assign materials = 'Metal,Acetate,Plastic' | split: ',' %}
            {% for material in materials %}
            <label class="zaman-filter-option">
              <input type="checkbox"
                name="filter.p.m.custom.material"
                value="{{ material }}"
                class="zaman-filter-check"
                {% if current_tags contains material %}
                  checked
                {% endif %}
                onchange="document.getElementById(
                  'ZamanFilterForm').submit()">
              <span class="zaman-check-box"></span>
              <span class="zaman-filter-text">
                {{ material }}
              </span>
            </label>
            {% endfor %}
          </div>
        </details>

        <!-- GENDER -->
        <details class="zaman-filter-group" open>
          <summary class="zaman-filter-group-title">
            Gender
            <span class="zaman-filter-arrow">▼</span>
          </summary>
          <div class="zaman-filter-options">
            {% assign genders = 'Men,Women,Unisex,Kids' | split: ',' %}
            {% for gender in genders %}
            <label class="zaman-filter-option">
              <input type="checkbox"
                name="filter.p.m.custom.gender"
                value="{{ gender }}"
                class="zaman-filter-check"
                {% if current_tags contains gender %}
                  checked
                {% endif %}
                onchange="document.getElementById(
                  'ZamanFilterForm').submit()">
              <span class="zaman-check-box"></span>
              <span class="zaman-filter-text">
                {{ gender }}
              </span>
            </label>
            {% endfor %}
          </div>
        </details>

        <!-- SIZE -->
        <details class="zaman-filter-group" open>
          <summary class="zaman-filter-group-title">
            Size
            <span class="zaman-filter-arrow">▼</span>
          </summary>
          <div class="zaman-filter-options">
            {% assign sizes = 'Medium,Wide' | split: ',' %}
            {% for size in sizes %}
            <label class="zaman-filter-option">
              <input type="checkbox"
                name="filter.p.m.custom.size"
                value="{{ size }}"
                class="zaman-filter-check"
                {% if current_tags contains size %}
                  checked
                {% endif %}
                onchange="document.getElementById(
                  'ZamanFilterForm').submit()">
              <span class="zaman-check-box"></span>
              <span class="zaman-filter-text">
                {{ size }}
              </span>
            </label>
            {% endfor %}
          </div>
        </details>

        <!-- PRICE -->
        <details class="zaman-filter-group">
          <summary class="zaman-filter-group-title">
            Price Range
            <span class="zaman-filter-arrow">▼</span>
          </summary>
          <div class="zaman-filter-options">
            <div class="zaman-price-inputs">
              <div class="zaman-price-field">
                <label>Min (Rs)</label>
                <input type="number" 
                       name="filter.v.price.gte"
                       placeholder="0"
                       class="zaman-price-input">
              </div>
              <span class="zaman-price-dash">—</span>
              <div class="zaman-price-field">
                <label>Max (Rs)</label>
                <input type="number"
                       name="filter.v.price.lte"
                       placeholder="10000"
                       class="zaman-price-input">
              </div>
            </div>
            <button type="submit" 
                    class="zaman-price-apply">
              Apply Price
            </button>
          </div>
        </details>

      </div><!-- end zaman-filter-card -->
    </form>
  </aside>

  <!-- RIGHT: Products Area -->
  <div class="zaman-products-area">
    
    <!-- Sort + Count Bar -->
    <div class="zaman-sort-bar">
      <span class="zaman-results-count">
        <strong>{{ collection.products_count }}</strong> 
        products found
      </span>
      <div class="zaman-sort-wrap">
        <label for="ZamanSortBy">Sort by:</label>
        <select id="ZamanSortBy" 
                name="sort_by"
                class="zaman-sort-select"
                onchange="window.location.href = 
                  '{{ collection.url }}?sort_by=' + 
                  this.value">
          <option value="best-selling" 
            {% if collection.sort_by == 'best-selling' %}
              selected{% endif %}>
            Best Selling
          </option>
          <option value="title-ascending"
            {% if collection.sort_by == 'title-ascending' %}
              selected{% endif %}>
            Name: A–Z
          </option>
          <option value="title-descending"
            {% if collection.sort_by == 'title-descending' %}
              selected{% endif %}>
            Name: Z–A
          </option>
          <option value="price-ascending"
            {% if collection.sort_by == 'price-ascending' %}
              selected{% endif %}>
            Price: Low to High
          </option>
          <option value="price-descending"
            {% if collection.sort_by == 'price-descending' %}
              selected{% endif %}>
            Price: High to Low
          </option>
          <option value="created-descending"
            {% if collection.sort_by == 'created-descending' %}
              selected{% endif %}>
            Newest First
          </option>
        </select>
      </div>
    </div>

    <!-- Product Grid -->
    {% if collection.products.size > 0 %}
    <div class="zaman-product-grid">
      {% for product in collection.products %}
      <a href="{{ product.url }}" 
         class="zaman-product-card">
        
        <!-- Badge -->
        {% if product.available == false %}
        <div class="zaman-card-badge zaman-badge-sold">
          Sold Out
        </div>
        {% elsif product.compare_at_price > product.price %}
        <div class="zaman-card-badge zaman-badge-sale">
          Sale
        </div>
        {% else %}
        <div class="zaman-card-badge zaman-badge-new">
          New
        </div>
        {% endif %}

        <!-- Image -->
        <div class="zaman-card-image">
          {% if product.featured_image %}
          <img src="{{ product.featured_image 
                       | img_url: '500x400' }}"
               alt="{{ product.title }}"
               loading="lazy">
          {% else %}
          <div class="zaman-card-no-image">
            <svg width="48" height="48" fill="none" 
                 viewBox="0 0 24 24" stroke="#CCCCCC" 
                 stroke-width="1">
              <rect x="3" y="3" width="18" height="18" 
                    rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span>No Image</span>
          </div>
          {% endif %}
        </div>

        <!-- Info -->
        <div class="zaman-card-info">
          <div class="zaman-card-category">
            {{ collection.title }}
          </div>
          <h3 class="zaman-card-title">
            {{ product.title }}
          </h3>
          <div class="zaman-card-price-row">
            <span class="zaman-card-price">
              {{ product.price | money }}
            </span>
            {% if product.compare_at_price > product.price %}
            <span class="zaman-card-compare">
              {{ product.compare_at_price | money }}
            </span>
            {% endif %}
          </div>
          <div class="zaman-card-footer">
            <span class="zaman-card-cta">
              View Details →
            </span>
            {% unless product.available %}
            <span class="zaman-card-unavailable">
              Out of Stock
            </span>
            {% endunless %}
          </div>
        </div>

      </a>
      {% endfor %}
    </div>

    {% else %}
    <!-- Empty state -->
    <div class="zaman-empty-state">
      <svg width="64" height="64" fill="none" 
           viewBox="0 0 24 24" stroke="#DDDDDD" 
           stroke-width="1">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35" 
              stroke-linecap="round"/>
      </svg>
      <h3>No products found</h3>
      <p>Try adjusting your filters or 
         <a href="{{ collection.url }}">clear all</a>
      </p>
    </div>
    {% endif %}

    <!-- Pagination -->
    {% if paginate.pages > 1 %}
    <div class="zaman-pagination">
      {% if paginate.previous %}
      <a href="{{ paginate.previous.url }}" 
         class="zaman-page-btn">← Previous</a>
      {% endif %}
      {% for part in paginate.parts %}
        {% if part.is_link %}
        <a href="{{ part.url }}" 
           class="zaman-page-btn">{{ part.title }}</a>
        {% else %}
        <span class="zaman-page-btn zaman-page-current">
          {{ part.title }}
        </span>
        {% endif %}
      {% endfor %}
      {% if paginate.next %}
      <a href="{{ paginate.next.url }}" 
         class="zaman-page-btn">Next →</a>
      {% endif %}
    </div>
    {% endif %}

  </div><!-- end products area -->

</div><!-- end collection page -->

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    }
  ]
}
{% endschema %}
